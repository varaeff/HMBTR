# Production Docker Compose environment.
# Copy to .env on the VPS/Dokploy environment and replace every placeholder.
#
# Database safety:
# - Do not point these values at a local development database.
# - Do not reuse local PostgreSQL Docker volumes.
# - Production data is stored only in the hmbtr_prod_postgres_data volume.

POSTGRES_USER=hmbtr
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=hmbtr
POSTGRES_PUBLIC_PORT=5432
DATABASE_URL=postgresql://hmbtr:replace-with-a-long-random-password@postgres:5432/hmbtr

BACKEND_PORT=3000
BACKEND_PUBLIC_PORT=3001
FRONTEND_PUBLIC_PORT=8080

JWT_SECRET=replace-with-a-long-random-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-token-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=https://app.example.com
VITE_API_BASE_URL=https://api.example.com/api/hmbtr/v1

# Optional email configuration.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
