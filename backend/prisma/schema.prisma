generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// --- ГЕОГРАФИЯ И КЛУБЫ ---

model countries {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)

  cities      cities[]
  fighters    fighters[]
  marshals    marshals[]
  tournaments tournaments[]
}

model cities {
  id         Int    @id @default(autoincrement())
  country_id Int
  name       String @db.VarChar(255)

  country     countries     @relation(fields: [country_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clubs       clubs[]
  fighters    fighters[]
  marshals    marshals[]
  tournaments tournaments[]
}

model clubs {
  id      Int    @id @default(autoincrement())
  city_id Int
  name    String @db.VarChar(255)

  city     cities     @relation(fields: [city_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fighters fighters[]
}

// --- БОЙЦЫ И ТУРНИРЫ ---

model fighters {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  surname    String    @db.VarChar(255)
  patronymic String?   @db.VarChar(255)
  birthday   DateTime? @db.Date
  country_id Int
  city_id    Int
  club_id    Int?
  pic        String?
  is_male    Boolean   @default(true)

  country                   countries                           @relation(fields: [country_id], references: [id])
  city                      cities                              @relation(fields: [city_id], references: [id])
  club                      clubs?                              @relation(fields: [club_id], references: [id])
  competitors               competitors[]
  disciplinary_cards        disciplinary_cards[]
  nomination_ratings        fighter_nomination_ratings[]
  nomination_rating_history fighter_nomination_rating_history[]
}

model marshals {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  surname     String  @db.VarChar(255)
  patronymic  String? @db.VarChar(255)
  country_id  Int
  city_id     Int
  category_id Int
  pic         String?

  country     countries             @relation(fields: [country_id], references: [id])
  city        cities                @relation(fields: [city_id], references: [id])
  category    marshals_categories   @relation(fields: [category_id], references: [id])
  tournaments tournament_marshals[]
}

model marshals_categories {
  id      Int    @id @default(autoincrement())
  name_ru String @db.VarChar(255)
  name_en String @db.VarChar(255)

  marshals marshals[]
}

model tournaments {
  id                              Int       @id @default(autoincrement())
  name                            String    @db.VarChar(255)
  event_date                      DateTime? @db.Date
  country_id                      Int
  city_id                         Int
  is_marshals_registration_closed Boolean   @default(false)

  country                countries                           @relation(fields: [country_id], references: [id])
  city                   cities                              @relation(fields: [city_id], references: [id])
  nominations            tournament_nominations[]
  competitors            competitors[]
  groups                 groups[]
  fights                 fights[]
  reports                tournament_reports[]
  disciplinary_cards     disciplinary_cards[]
  fighter_rating_history fighter_nomination_rating_history[]
  marshals               tournament_marshals[]
}

model tournament_marshals {
  id            Int      @id @default(autoincrement())
  tournament_id Int
  marshal_id    Int
  created_at    DateTime @default(now())

  tournament tournaments @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  marshal    marshals    @relation(fields: [marshal_id], references: [id], onDelete: Cascade)

  @@unique([tournament_id, marshal_id])
  @@index([marshal_id])
}

model nominations {
  id      Int     @id @default(autoincrement())
  name_ru String  @db.VarChar(255)
  name_en String  @db.VarChar(255)
  is_male Boolean @default(true)

  tournaments            tournament_nominations[]
  competitors            competitors[]
  groups                 groups[]
  fights                 fights[]
  fighter_ratings        fighter_nomination_ratings[]
  fighter_rating_history fighter_nomination_rating_history[]
}

// --- СОРЕВНОВАТЕЛЬНАЯ ЛОГИКА ---

model tournament_nominations {
  id                   Int       @id @default(autoincrement())
  tournament_id        Int
  nomination_id        Int
  is_open              Boolean   @default(true)
  is_finished          Boolean   @default(false)
  stage                Int       @default(0)
  rating_status        String    @default("PENDING") @db.VarChar(32)
  rating_calculated_at DateTime?
  rating_error         String?   @db.Text

  tournament     tournaments                         @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  nomination     nominations                         @relation(fields: [nomination_id], references: [id], onDelete: Cascade)
  blocks         competition_blocks[]
  placements     competition_placements[]
  rating_history fighter_nomination_rating_history[]
}

model competitors {
  id            Int @id @default(autoincrement())
  fighter_id    Int
  tournament_id Int
  nomination_id Int
  stage         Int @default(0)

  fighter       fighters                 @relation(fields: [fighter_id], references: [id], onDelete: Cascade)
  tournament    tournaments              @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  nomination    nominations              @relation(fields: [nomination_id], references: [id], onDelete: Cascade)
  groups        group_competitors[]
  bracket_slots bracket_slots[]
  placements    competition_placements[]

  // Связи для таблицы боев (кто участвовал)
  fights_as_f1 fights[] @relation("Fighter1")
  fights_as_f2 fights[] @relation("Fighter2")
  fights_won   fights[] @relation("Winner")
}

model groups {
  id            Int    @id @default(autoincrement())
  tournament_id Int
  nomination_id Int
  block_id      Int?
  name          String @db.VarChar(255)
  stage         Int    @default(0)

  tournament tournaments              @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  nomination nominations              @relation(fields: [nomination_id], references: [id], onDelete: Cascade)
  block      competition_blocks?      @relation(fields: [block_id], references: [id], onDelete: Cascade)
  fighters   group_competitors[]
  fights     fights[]
  placements competition_placements[]
}

model group_competitors {
  id            Int @id @default(autoincrement())
  group_id      Int
  competitor_id Int

  group      groups      @relation(fields: [group_id], references: [id], onDelete: Cascade)
  competitor competitors @relation(fields: [competitor_id], references: [id], onDelete: Cascade)
}

model fights {
  id                Int     @id @default(autoincrement())
  tournament_id     Int
  nomination_id     Int
  block_id          Int?
  group_id          Int?
  competitor1_id    Int
  competitor2_id    Int
  competitor1_score Int     @default(0)
  competitor2_score Int     @default(0)
  winner_id         Int?
  stage             Int     @default(0)
  fight_number      Int     @default(0)
  bracket_round     Int?
  bracket_position  Int?
  is_bronze         Boolean @default(false)
  is_finished       Boolean @default(false)
  forfeit_card_id   Int?

  tournament tournaments         @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  nomination nominations         @relation(fields: [nomination_id], references: [id], onDelete: Cascade)
  block      competition_blocks? @relation(fields: [block_id], references: [id], onDelete: Cascade)
  group      groups?             @relation(fields: [group_id], references: [id])

  // Именованные связи для различения двух бойцов
  competitor1        competitors          @relation("Fighter1", fields: [competitor1_id], references: [id])
  competitor2        competitors          @relation("Fighter2", fields: [competitor2_id], references: [id])
  winner             competitors?         @relation("Winner", fields: [winner_id], references: [id])
  disciplinary_cards disciplinary_cards[]

  @@index([forfeit_card_id])
}

model disciplinary_cards {
  id            Int      @id @default(autoincrement())
  fighter_id    Int
  tournament_id Int
  fight_id      Int
  type          String   @db.VarChar(16)
  source        String   @default("MANUAL") @db.VarChar(16)
  received_at   DateTime @db.Date
  reason        String   @db.Text
  expires_at    DateTime @db.Date
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  fighter    fighters    @relation(fields: [fighter_id], references: [id], onDelete: Cascade)
  tournament tournaments @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  fight      fights      @relation(fields: [fight_id], references: [id], onDelete: Cascade)

  @@index([fighter_id, type, received_at, expires_at])
  @@index([tournament_id])
  @@index([fight_id])
}

model fighter_nomination_ratings {
  id            Int      @id @default(autoincrement())
  nomination_id Int
  fighter_id    Int
  rating        Int      @default(1000)
  fights_count  Int      @default(0)
  updated_at    DateTime @updatedAt

  nomination nominations @relation(fields: [nomination_id], references: [id], onDelete: Cascade)
  fighter    fighters    @relation(fields: [fighter_id], references: [id], onDelete: Cascade)

  @@unique([nomination_id, fighter_id])
  @@index([nomination_id, rating])
}

model fighter_nomination_rating_history {
  id                       Int      @id @default(autoincrement())
  nomination_id            Int
  fighter_id               Int
  tournament_id            Int
  tournament_nomination_id Int
  rating_before            Int
  rating_after             Int
  fights_count_delta       Int
  created_at               DateTime @default(now())

  nomination            nominations            @relation(fields: [nomination_id], references: [id], onDelete: Cascade)
  fighter               fighters               @relation(fields: [fighter_id], references: [id], onDelete: Cascade)
  tournament            tournaments            @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  tournament_nomination tournament_nominations @relation(fields: [tournament_nomination_id], references: [id], onDelete: Cascade)

  @@unique([tournament_nomination_id, fighter_id])
  @@index([nomination_id, fighter_id, tournament_id])
}

model competition_blocks {
  id                       Int      @id @default(autoincrement())
  tournament_nomination_id Int
  tournament_id            Int
  nomination_id            Int
  type                     String   @db.VarChar(32)
  stage                    Int
  status                   String   @default("ACTIVE") @db.VarChar(32)
  lifecycle_state          String   @default("FORMATION_EDITABLE") @db.VarChar(32)
  created_at               DateTime @default(now())

  tournament_nomination tournament_nominations   @relation(fields: [tournament_nomination_id], references: [id], onDelete: Cascade)
  groups                groups[]
  fights                fights[]
  bracket_slots         bracket_slots[]
  placements            competition_placements[]
  round_states          competition_round_states[]
}

model competition_round_states {
  id            Int     @id @default(autoincrement())
  block_id      Int
  round         Int
  pairs_fixed   Boolean @default(false)
  results_fixed Boolean @default(false)

  block competition_blocks @relation(fields: [block_id], references: [id], onDelete: Cascade)

  @@unique([block_id, round])
}

model bracket_slots {
  id            Int @id @default(autoincrement())
  block_id      Int
  competitor_id Int
  seed_position Int
  slot_position Int

  block      competition_blocks @relation(fields: [block_id], references: [id], onDelete: Cascade)
  competitor competitors        @relation(fields: [competitor_id], references: [id], onDelete: Cascade)

  @@unique([block_id, slot_position])
  @@unique([block_id, competitor_id])
}

model competition_placements {
  id                       Int    @id @default(autoincrement())
  tournament_nomination_id Int
  block_id                 Int?
  group_id                 Int?
  competitor_id            Int
  scope                    String @db.VarChar(32)
  place                    Int

  tournament_nomination tournament_nominations @relation(fields: [tournament_nomination_id], references: [id], onDelete: Cascade)
  block                 competition_blocks?    @relation(fields: [block_id], references: [id], onDelete: Cascade)
  group                 groups?                @relation(fields: [group_id], references: [id], onDelete: Cascade)
  competitor            competitors            @relation(fields: [competitor_id], references: [id], onDelete: Cascade)

  @@unique([tournament_nomination_id, scope, group_id, place], map: "competition_placements_group_place_key")
  @@unique([tournament_nomination_id, scope, group_id, competitor_id], map: "competition_placements_group_competitor_key")
}

// --- ПОЛЬЗОВАТЕЛИ ---

model tournament_reports {
  id            Int      @id @default(autoincrement())
  tournament_id Int
  language      String   @db.VarChar(8)
  file_name     String   @db.VarChar(255)
  pdf_data      Bytes
  generated_at  DateTime @default(now())

  tournament tournaments @relation(fields: [tournament_id], references: [id], onDelete: Cascade)

  @@unique([tournament_id, language])
}

model users {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(255)
  password     String   @db.VarChar(255)
  surname      String   @db.VarChar(255)
  name         String   @db.VarChar(255)
  patronymic   String?  @db.VarChar(255)
  email        String?  @unique @db.VarChar(255)
  is_admin     Boolean  @default(false)
  is_organizer Boolean  @default(false)
  is_secretary Boolean  @default(false)
  refreshToken String?  @db.Text
  createdAt    DateTime @default(now())
}
